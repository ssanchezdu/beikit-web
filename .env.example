# Instagram Graph API — build-time credentials.
# Copy this file to `.env` (never commit the real values — `.env` is gitignored).
# These vars are read ONLY by fetch-instagram.mjs at build time; they are never
# bundled into the client, so the token is safe as long as `.env` stays local/CI-only.
#
# How to obtain them:
# 1. The Instagram account must be Business or Creator, linked to a Facebook Page.
# 2. Create an app at https://developers.facebook.com → add the Instagram product.
# 3. Generate a long-lived access token with the `instagram_basic` permission.
# 4. Query `GET /me/accounts?access_token=…` → use `instagram_business_account.id`.
#
# Refresh reminder: long-lived tokens expire after 60 days. Regenerate or automate.

IG_ACCESS_TOKEN=
IG_USER_ID=

# Formspree endpoint for the catering form (https://formspree.io → create form).
# Prefixed VITE_ so Vite exposes it to the client bundle. Without it, the form
# shows an error on submit in production (and skips the request in dev).
VITE_FORMSPREE_ENDPOINT=

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX).
# The GA script is loaded ONLY after the user accepts cookies. Without this
# value the cookie banner still works; analytics is simply a no-op.
VITE_GA_MEASUREMENT_ID=
